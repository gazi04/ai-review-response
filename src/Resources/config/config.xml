<?xml version="1.0" encoding="UTF-8"?>

<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/shopware/shopware/trunk/src/Core/System/SystemConfig/Schema/config.xsd">

    <card>
        <title>AI Proxy Settings</title>

        <input-field type="text">
            <name>openaiEndpoint</name>
            <label>Inference Endpoint</label>
            <defaultValue>https://models.github.ai/inference</defaultValue>
            <helpText>The base URL for the AI API (e.g. GitHub Models or Azure)</helpText>
        </input-field>

        <input-field type="text">
            <name>openaiModel</name>
            <label>Model Name</label>
            <defaultValue>openai/gpt-4.1</defaultValue>
        </input-field>

        <input-field type="password">
            <name>openaiApiKey</name>
            <label>Token / API Key</label>
            <helpText>Your GitHub Token or OpenAI Key</helpText>
        </input-field>
    </card>

</config>

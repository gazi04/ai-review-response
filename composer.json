{
    "name": "ai-review-respond/ai-review-respond",
    "description": "ai-review-respond/ai-review-respond",
    "type": "shopware-platform-plugin",
    "version": "1.0.0",
    "license": "MIT",
    "require": {
        "shopware/core": "~6.7.0",
        "openai-php/client": "^0.19.0"
    },
    "extra": {
        "shopware-plugin-class": "AiReviewRespond\\AiReviewRespond",
        "label": {
            "de-DE": "KI-Bewertung antwortet",
            "en-GB": "Ai Review Respond"
        }
    },
    "autoload": {
        "psr-4": {
            "AiReviewRespond\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AiReviewRespond\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "symfony/runtime": true,
            "php-http/discovery": true
        }
    }
}
